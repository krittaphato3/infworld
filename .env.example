# ── LLM Configuration ──────────────────────────────────
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=gpt-4o

# ── Image Generation API (DALL-E / Stable Diffusion) ──
IMAGE_API_URL=https://api.openai.com/v1
IMAGE_API_KEY=sk-your-api-key-here
IMAGE_MODEL=dall-e-3

# ── Audio Generation API (Music/SFX) ───────────────────
AUDIO_API_URL=https://api.openai.com/v1
AUDIO_API_KEY=sk-your-api-key-here
AUDIO_MODEL=tts-1

# ── Application Settings ───────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
GENERATED_DIR=generated
